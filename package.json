{
  "name": "svg-maker",
  "version": "1.0.0",
  "description": "A workspace for generated SVGs using Sesi built-in functions from the std/draw library.",
  "main": "node_modules/@misterscan/sesi/dist/index.js",
  "bin": {
    "sesi": "bin/sesi.js"
  },
  "license": "MIT",
  "author": "misterscan",
  "private": true,
  "scripts": {
    "sesi": "node bin/sesi.js",
    "local": "node bin/sesi.js --cli -l",
    "start": "node bin/sesi.js --cli -l main.sesi",
    "web": "node bin/sesi.js --cli -l ui.sesi",
    "eval": "node bin/sesi.js --cli -e",
    "help": "node bin/sesi.js --cli -h",
    "lint": "node bin/sesi.js --cli bin/lint.sesi",
    "encrypt": "node bin/sesi.js --cli -enc",
    "decrypt": "node bin/sesi.js --cli -dec"
  },
  "dependencies": {
    "@misterscan/sesi": "1.6.4"
  },
  "allowScripts": {
    "@google/genai@2.12.0": true,
    "protobufjs@7.6.4": true
  }
}